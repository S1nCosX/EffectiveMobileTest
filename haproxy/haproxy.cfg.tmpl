global
    user haproxy
    group haproxy

defaults
    mode http
    timeout connect 5s
    timeout client 15s
    timeout server 15s

frontend http-in
    bind 0.0.0.0:80
    default_backend servers

frontend health
  mode http
  bind 127.0.0.1:80
  http-request return status 200 if { src 127.0.0.0/8 }

backend servers
    balance leastconn
    option httpchk GET /health
{{ range service "server" }}
    {{ if eq .Status "passing"}}
    server {{ .ID }} {{ .Address }}:{{ .Port }} check
    {{ end }}
{{end}}
